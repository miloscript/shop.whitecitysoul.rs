    {
      "type": "header",
      "content": "t:content.sorting"
    },
    {
      "type": "select",
      "id": "default_sort",
      "label": "t:settings.default_sort",
      "options": [
        { "value": "price-asc", "label": "t:options.sort_price_asc" },
        { "value": "price-desc", "label": "t:options.sort_price_desc" },
        { "value": "name-asc", "label": "t:options.sort_name_asc" },
        { "value": "name-desc", "label": "t:options.sort_name_desc" }
      ],
      "default": "price-asc"
    },
    {
      "type": "checkbox",
      "id": "show_sort_price_asc",
      "label": "t:settings.show_sort_price_asc",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort_price_desc",
      "label": "t:settings.show_sort_price_desc",
      "default": true
    },
