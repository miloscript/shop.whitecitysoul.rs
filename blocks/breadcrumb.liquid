{%- liquid
  assign separator = block.settings.separator | default: '/'
  assign product_title = closest.product.title
-%}

<nav
  class="breadcrumb spacing-style"
  aria-label="{{ 'accessibility.breadcrumb' | t }}"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  <ol class="breadcrumb__list" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="{{ routes.root_url }}" itemprop="item">
        <span itemprop="name">{{ 'breadcrumb.home' | t }}</span>
      </a>
      <meta itemprop="position" content="1">
    </li>

    {%- if collection -%}
      <li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span class="breadcrumb__separator" aria-hidden="true">{{ separator }}</span>
        <a href="{{ collection.url }}" itemprop="item">
          <span itemprop="name">{{ collection.title }}</span>
        </a>
        <meta itemprop="position" content="2">
      </li>
      <li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
        <span class="breadcrumb__separator" aria-hidden="true">{{ separator }}</span>
        <span itemprop="name">{{ product_title }}</span>
        <meta itemprop="position" content="3">
      </li>
    {%- else -%}
      <li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
        <span class="breadcrumb__separator" aria-hidden="true">{{ separator }}</span>
        <span itemprop="name">{{ product_title }}</span>
        <meta itemprop="position" content="2">
      </li>
    {%- endif -%}
  </ol>
</nav>

{% stylesheet %}
  .breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 0.5em;
    align-items: center;
  }

  .breadcrumb__item {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--font-paragraph-small--size);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .breadcrumb__item a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb__item a:hover {
    text-decoration: underline;
  }

  .breadcrumb__item[aria-current="page"] {
    color: var(--color-foreground);
  }

  .breadcrumb__separator {
    user-select: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.breadcrumb",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "separator",
      "label": "t:settings.separator",
      "default": "/"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.breadcrumb",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
